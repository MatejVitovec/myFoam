FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

//riemannSolver           mslau2;
riemannSolver           slau2;

ddtSchemes
{
    default             Euler; 
}

gradSchemes
{
    default             Gauss linear;
    limitedGauss        cellLimited Gauss linear 1;
    venkatakrishnan     cellLimited<cubic> 2 edgeCellsLeastSquares 1;
}

divSchemes
{
    default             none;
    div(alphaRhoPhi2,w_Q)    Gauss multivariateIndependent
    {
        "Q.*" upwind;
    };

    div(alphaRhoPhi2L,n)	Gauss upwind;
    div(rhoPhi,n)		Gauss upwind;
    div(interpolate(U.1),U.1)   Gauss linear;
    div(interpolate(U.2),U.2)   Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;

    reconstruct(p)      linearUpwind  venkatakrishnan;
    reconstruct(alpha)  linearUpwind  venkatakrishnan;
    reconstruct(U.1)    linearUpwindV venkatakrishnan;
    reconstruct(U.2)    linearUpwindV venkatakrishnan;
    reconstruct(T.1)    linearUpwind  venkatakrishnan;
    reconstruct(T.2)    linearUpwind  venkatakrishnan;

    //reconstruct(p)      upwind;
    //reconstruct(alpha)  upwind;
    //reconstruct(U)      upwind;
    //reconstruct(T)      upwind;
    //reconstruct(w)      upwind;
    //reconstruct(U.1)    upwind;
    //reconstruct(U.2)    upwind;
    //reconstruct(T.1)    upwind;
    //reconstruct(T.2)    upwind;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
}

